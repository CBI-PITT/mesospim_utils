DOCKER_HUB_REPO=cbipitt/mesospim_utils
TAG=test

CONTAINER_TIMEZONE=America/New_York
CONTAINER_UBUNTU_VERSION=22.04
CONTAINER_HOSTNAME=mesospim-utils

CONTAINER_USERNAME=docker
CONTAINER_PASSWORD=ubuntu
CONTAINER_UID=1000

SLURM_VER=25.05.3

MINICONDA_DIR=/opt/miniconda
MINICONDA_VERSION=py312_24.7.1-0
MINICONDA_OS=Linux
MINICONDA_ARCH=x86_64

WINE_GITHUB=https://github.com/wine-mirror/wine.git
WINE_COMMIT=2bca8cb236b7d4d5f4e0e35d6fcad6a1d8a2c5e3

# Host mount sources.
# Defaults target Docker launched from cmd.exe or PowerShell on Windows.
# If running Docker from WSL instead, override these with /mnt/<drive>/... or other
# WSL-visible paths before launching compose.
MESO_C_SRC=C:\data
MESO_Z_SRC=//faststore.cbi.pitt.edu/CBI_FastStore
MESO_H_SRC=//tn.cbi.pitt.edu/h20
MESO_CONFIG_SRC=./config
MESO_WORK_SRC=./work

# CIFS mount options used by Docker's SMB-backed volumes for Z: and H:.
# These defaults assume open/guest shares. For authenticated shares, replace
# with something like:
# username=myuser,password=mypass,domain=TN,vers=3.0,file_mode=0777,dir_mode=0777,noperm,iocharset=utf8
MESO_Z_CIFS_OPTS=guest,vers=3.0,file_mode=0777,dir_mode=0777,noperm,iocharset=utf8
MESO_H_CIFS_OPTS=guest,vers=3.0,file_mode=0777,dir_mode=0777,noperm,iocharset=utf8

# Optional. If left as the disabled-share placeholder the container will mount
# an empty local directory at /data/share.
MESO_SHARE_SRC=./disabled-share
